#!/usr/bin/env php
<?php
namespace BrainGames\Cli;
/**
 * PHP version 2222
 * fgh@category $this is a category.
 * ghj@package $this is a category.
 * fty@author $this is a category.
 * lkj@license $this is a category.
 * nbv@link $this is a category.
 */

$autoloadPath1 = __DIR__ . '/../../../autoload.php';
$autoloadPath2 = __DIR__ . '/../vendor/autoload.php';

if (file_exists($autoloadPath1)) {
    require_once $autoloadPath1;
} else {
    require_once $autoloadPath2;
}

use function cli\line;
use function cli\prompt;
use function cli\out;
use function cli\err;

line("Welcome to the Brain Game!");
$name = prompt("May I have your name?");
line("Hello, %s!", $name);
$count = 0;
$correctAnswerCount = 3;
while ($count < $correctAnswerCount) {
    line("Answer \"yes\" if the number is even, otherwise answer \"no\".");
    $int = rand(1, 50);
    line("Question: " . $int);
    $answer = prompt("Your answer");
    if (($int % 2) === 0) {
        if ($answer == "yes") {
            out("Correct! \n");
            $count++;
        } else {
            err($answer . " is wrong answer ;(. Correct answer was \"yes\". \n
Let\'s try again," . $name . "!");
            $count = 0;
        }
    } elseif (($int % 2) !== 0) {
        if ($answer == "no") {
            out("Correct! \n");
            $count++;
        } else {
            err("\"yes\" is wrong answer ;(. Correct answer was \"no\". \n
Let\'s try again, " . $name  . "!");
            $count = 0;
    }
}
if ($count == 3) {
    out("Congratulations, " . $name  . "!");
    }
}

